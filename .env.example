BOT_TOKEN=
WEB_APP_URL=
API_HOST=0.0.0.0
API_PORT=8090

# FTP credentials (required for privilege issuing in users.ini)
FTP_HOST=
FTP_PORT=21
FTP_USER=
FTP_PASSWORD=
FTP_TIMEOUT_SECONDS=20
FTP_USERS_INI_SUFFIX=cs/cstrike/addons/amxmodx/configs/users.ini

# Optional: override server->folder mapping (JSON object by port)
# FTP_SERVER_FOLDERS_BY_PORT={"27015":"service#790","27016":"service#802"}

# phpMyAdmin credentials (required for bonus purchase)
PHPMYADMIN_BASE_URL=
PHPMYADMIN_LOGIN=
PHPMYADMIN_PASSWORD=
PHPMYADMIN_SERVER=1

BONUS_DB_PUBLIC=c_2strike
BONUS_TABLE_NAME=AesStatsPublic
BONUS_ROW_ID_COLUMN=id
BONUS_STEAM_ID_COLUMN=steamid
BONUS_NAME_COLUMN=name
BONUS_VALUE_COLUMN=bonus_count

# Payment verification (screenshot OCR + @HUMOcardbot reconciliation)
PAYMENT_VERIFICATION_REQUIRED=1
OPENAI_API_KEY=
PAYMENT_OPENAI_MODEL=gpt-4o-mini
PAYMENT_AMOUNT_TOLERANCE=0
PAYMENT_SCREENSHOT_MAX_AGE_HOURS=72
PAYMENT_TRANSFER_TIME_TOLERANCE_HOURS=36
PAYMENT_TRANSFER_RECENT_WINDOW_MINUTES=20
PAYMENT_MAX_SCREENSHOT_ATTEMPTS=3
PAYMENT_ATTEMPT_WINDOW_SECONDS=7200
PAYMENT_USER_BAN_SECONDS=600
PAYMENT_USER_FAILURE_WINDOW_SECONDS=7200
PAYMENT_UPLOAD_SESSION_SECONDS=300

# Recipient hints used by OCR validator (at least one block must be filled)
# Example: PAYMENT_RECIPIENT_CARD_LAST4=1234,5678
PAYMENT_RECIPIENT_CARD_LAST4=
# Example: PAYMENT_RECIPIENT_NAMES=FAYZIKHANOV,ФАЙЗИХАНОВ
PAYMENT_RECIPIENT_NAMES=
# Example: PAYMENT_RECIPIENT_CARD_HINTS=86001234,HUMO*1234
PAYMENT_RECIPIENT_CARD_HINTS=

# User account API access for @HUMOcardbot (not bot token)
TELEGRAM_APP_API_ID=
TELEGRAM_APP_API_HASH=
# Preferred: pre-authorized session string for non-interactive server runs
TELEGRAM_SESSION_STRING=
# Optional session file path if you authorize locally in terminal
TELEGRAM_SESSION_FILE=data/humo_telegram.session
HUMO_BOT_USERNAME=@HUMOcardbot
HUMO_BALANCE_COMMAND=💰 Баланс
HUMO_MESSAGE_LIMIT=60
HUMO_LOOKBACK_HOURS=24
HUMO_BALANCE_WAIT_SECONDS=5
HUMO_BALANCE_STATE_PATH=data/humo_balance_state.json
HUMO_CONSUMED_STATE_PATH=data/humo_consumed_payments.json
